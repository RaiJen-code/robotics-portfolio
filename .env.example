# ─────────────────────────────────────────────────────────────
# .env.example — Template environment variables
#
# CARA PAKAI:
#   1. Copy file ini: cp .env.example .env.local
#   2. Isi nilai yang sebenarnya di .env.local
#   3. File .env.local TIDAK boleh di-commit ke GitHub (sudah ada di .gitignore)
#
# Untuk production (GitHub Pages), set nilai-nilai ini di:
# GitHub repo → Settings → Secrets and Variables → Actions → New repository secret
# ─────────────────────────────────────────────────────────────

# Nama repo GitHub (contoh: /robotics-portfolio)
# Kosongkan jika pakai custom domain (misal: raijen.dev)
REPO_NAME=/robotics-portfolio

# n8n Webhook URLs
# Dapatkan dari: n8n → Workflow → Webhook node → Copy URL
N8N_CHAT_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/portfolio-chat
N8N_SERVICE_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/service-request
N8N_CONTACT_WEBHOOK=https://your-n8n.app.n8n.cloud/webhook/contact-form

# Formspree (alternatif form handler gratis — daftar di formspree.io)
# Gratis 50 submission/bulan
FORMSPREE_ID=xyzabcde

# URL website live di GitHub Pages
SITE_URL=https://RaiJen-code.github.io
